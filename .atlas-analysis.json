  "keyFeatures": [
    "Modular Terraform architecture with six reusable child modules",
    "Highly available multi-tier deployment across two AWS Availability Zones",
    "Application Load Balancer distributing traffic across two Node.js/Nginx EC2 instances",
    "MongoDB server isolated in a private subnet with NAT Gateway for outbound access",
    "Automated user-data provisioning of Node.js 22, Express, Nginx, and MongoDB 8.0",
    "Auto-generated RSA 4096-bit SSH key pair stored locally as a .pem file",
    "IAM instance profile with AmazonSSMManagedInstanceCore for session manager access",
    "S3 remote state backend for team-friendly state management",
    "IMDSv2 enforced on all EC2 instances with encrypted gp3 EBS root volumes",
    "Common tagging strategy via Terraform locals for consistent resource management"
  ],
